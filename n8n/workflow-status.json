    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/storage/v1/object/renders/{{ $('Parse Replicate Status').first().json.jobId }}/output.jpg",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "x-upsert",      "value": "true" }
          ]
        },
        "sendBody": true,
        "contentType": "binaryData",
        "inputDataFieldName": "imageData"
      },
      "id": "bb000017-0000-0000-0000-000000000017",
      "name": "Upload to Supabase Storage",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2180, 640]
    },
    {
      "parameters": {
        "jsCode": "const jobId   = $('Parse Replicate Status').first().json.jobId;\nconst supaUrl = ($env.SUPABASE_URL || '').replace(/\\/$/, '');\nconst publicUrl = `${supaUrl}/storage/v1/object/public/renders/${jobId}/output.jpg`;\nreturn [{ json: { jobId, outputUrl: publicUrl } }];"
      },
      "id": "bb000018-0000-0000-0000-000000000018",
      "name": "Build Public URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 640]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/render_jobs?id=eq.{{ $json.jobId }}",
        "sendHeaders": true,
