    {
      "parameters": {
        "mode": "rules",
        "output": "input",
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [{ "id": "rs1", "leftValue": "={{ $('Parse Replicate Status').first().json.replicateStatus }}", "rightValue": "succeeded", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "conditions": [{ "id": "rs2", "leftValue": "={{ $('Parse Replicate Status').first().json.replicateStatus }}", "rightValue": "failed", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              }
            }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "bb000015-0000-0000-0000-000000000015",
      "name": "Switch: Replicate Status",
