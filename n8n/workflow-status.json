      },
      "id": "bb000001-0000-0000-0000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 400],
      "webhookId": "bpcuisines-render-status-v1"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/render_jobs?id=eq.{{ $json.query.id }}&select=*&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "bb000002-0000-0000-0000-000000000002",
      "name": "Get Job from Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "jsCode": "const rows  = $input.all().map(i => i.json);\nconst jobId = $('Webhook').first().json.query?.id;\n\nif (!jobId) {\n  return [{ json: {\n    __route:   'not_found',\n    jobId:     null,\n    status:    'not_found',\n    outputUrl: null,\n    error:     'Missing id query parameter',\n  }}];\n}\n\n// Supabase REST returns an array\nconst arr = Array.isArray(rows[0]) ? rows[0] : rows;\nconst job = arr.find(r => r && r.id) || null;\n\nif (!job) {\n  return [{ json: {\n    __route:   'not_found',\n    jobId,\n    status:    'not_found',\n    outputUrl: null,\n    error:     'Unknown job id',\n  }}];\n}\n\nconst isTerminal = ['succeeded', 'failed', 'canceled'].includes(job.status);\n\n// Timeout check: if still processing after 10 minutes, mark as timed out\nconst createdAt = job.created_at ? new Date(job.created_at) : null;\nconst ageMs = createdAt ? (Date.now() - createdAt.getTime()) : 0;\nconst isTimedOut = !isTerminal && ageMs > 10 * 60 * 1000;\n\nif (isTimedOut) {\n  return [{ json: {\n    __route:   'timed_out',\n    jobId:     job.id,\n    status:    'failed',\n    outputUrl: null,\n    error:     'Render timed out after 10 minutes',\n    replicateId: job.replicate_id || null,\n  }}];\n}\n\nif (isTerminal) {\n  return [{ json: {\n    __route:      'terminal',\n    jobId:        job.id,\n    status:       job.status,\n    outputUrl:    job.output_url || null,\n    error:        job.error_message || job.error || null,\n    replicateId:  job.replicate_id || null,\n  }}];\n}\n\n// Throttle: if last_checked_at < 3 seconds ago, skip Replicate call\nconst lastChecked = job.last_checked_at ? new Date(job.last_checked_at) : null;\nconst msSinceCheck = lastChecked ? (Date.now() - lastChecked.getTime()) : Infinity;\nconst useCache = msSinceCheck < 3000;\n\nreturn [{ json: {\n  __route:      useCache ? 'cached' : 'check_replicate',\n  jobId:        job.id,\n  status:       job.status,\n  outputUrl:    job.output_url || null,\n  error:        job.error_message || job.error || null,\n  replicateId:  job.replicate_id || null,\n}}];"
      },
      "id": "bb000003-0000-0000-0000-000000000003",
      "name": "Parse Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 400]
    },
    {
      "parameters": {
        "mode": "rules",
        "output": "input",
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [{ "id": "r1", "leftValue": "={{ $json.__route }}", "rightValue": "not_found",      "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "conditions": [{ "id": "r2", "leftValue": "={{ $json.__route }}", "rightValue": "timed_out",      "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "conditions": [{ "id": "r3", "leftValue": "={{ $json.__route }}", "rightValue": "terminal",       "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "conditions": [{ "id": "r4", "leftValue": "={{ $json.__route }}", "rightValue": "cached",         "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              }
            }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "bb000004-0000-0000-0000-000000000004",
      "name": "Switch: Route",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [860, 400]
    },

    {
      "parameters": {
        "respondWith": "json",
