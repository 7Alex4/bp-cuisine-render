      "id": "bb000009-0000-0000-0000-000000000009",
      "name": "Respond — 200 Terminal OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1300, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ id: $json.jobId, status: $json.status, outputUrl: null, error: $json.error }) }}",
