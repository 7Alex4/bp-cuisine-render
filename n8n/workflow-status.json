      "id": "bb000011-0000-0000-0000-000000000011",
      "name": "Respond — 200 Cached Processing",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1080, 620]
    },

    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.replicate.com/v1/predictions/{{ $json.replicateId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.REPLICATE_API_TOKEN }}" }
          ]
        },
        "options": {}
      },
      "id": "bb000012-0000-0000-0000-000000000012",
      "name": "Check Replicate Prediction",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 760]
    },
    {
      "parameters": {
        "jsCode": "const item       = $input.first();\nconst prediction = item.json;\nconst parsed     = $('Parse Job').first().json;\n\nconst replicateStatus = prediction.status;\nconst outputUrl = Array.isArray(prediction.output) ? prediction.output[0] : (prediction.output ?? null);\nconst error     = prediction.error ?? null;\n\nreturn [{ json: {\n  jobId:          parsed.jobId,\n  replicateStatus,\n  outputUrl,\n  error,\n} }];"
      },
      "id": "bb000013-0000-0000-0000-000000000013",
      "name": "Parse Replicate Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 760]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/render_jobs?id=eq.{{ $json.jobId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ last_checked_at: new Date().toISOString() }) }}"
      },
      "id": "bb000014-0000-0000-0000-000000000014",
      "name": "Update last_checked_at",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
